generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "postgresql"
}

model File {

  id String @id @default(uuid())

  uploadedBy String

  originalName String

  objectName String

  bucket String

  mimeType String

  size Int

  type FileType

  etag String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt()

  @@index([uploadedBy])
  @@index([type])
  @@index([bucket])
}

enum FileType {

  AVATAR

  ATTACHMENT

  IMAGE

  PDF

}